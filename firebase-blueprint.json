{
  "entities": {
    "SystemState": {
      "title": "System State",
      "description": "Global state for the polling system",
      "type": "object",
      "properties": {
        "currentPollNumber": { "type": "number" },
        "isActive": { "type": "boolean" },
        "durationSeconds": { "type": "number" },
        "endsAt": { "type": "object", "format": "google-firestore-timestamp" },
        "lastPushedAt": { "type": "object", "format": "google-firestore-timestamp" }
      },
      "required": ["currentPollNumber", "isActive"]
    },
    "Vote": {
      "title": "Vote",
      "description": "A single vote cast by a user",
      "type": "object",
      "properties": {
        "pollNumber": { "type": "number" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "choice": { "type": "string", "enum": ["bias", "reality"] },
        "timestamp": { "type": "object", "format": "google-firestore-timestamp" }
      },
      "required": ["pollNumber", "userId", "userEmail", "userName", "choice", "timestamp"]
    }
  },
  "firestore": {
    "/system/state": {
      "schema": "SystemState",
      "description": "Singleton document for system state"
    },
    "/votes/{voteId}": {
      "schema": "Vote",
      "description": "Collection of votes, indexed by pollNumber_userId"
    }
  }
}
